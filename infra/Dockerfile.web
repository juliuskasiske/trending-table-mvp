# Build the Vite SPA (onboarding + control tower) and serve it with Caddy,
# which also reverse-proxies /api to the backend and terminates TLS.
# Build context is the mvp/ root: docker build -f infra/Dockerfile.web ..

FROM node:22-alpine AS build
WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm ci || npm install
COPY . .
RUN npm run build          # tsc + vite build -> dist/ (index.html + admin.html)

FROM caddy:2-alpine
COPY infra/Caddyfile /etc/caddy/Caddyfile
COPY --from=build /app/dist /srv/dist
