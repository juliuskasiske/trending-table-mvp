# Compose-level vars for infra/docker-compose.prod.yml.
# Copy to infra/.env and fill in. Keep POSTGRES_USER/PASSWORD identical to the
# credentials used in the DB URLs inside backend/.env.prod.

POSTGRES_USER=tt_owner
POSTGRES_PASSWORD=change-me-strong-db-password

# Mount point of the attached Hetzner Volume (Postgres data dir).
PGDATA_DIR=/mnt/pgdata

# Your hostname — Caddy gets a Let's Encrypt cert for it automatically.
# Use :80 for a quick no-TLS test.
SITE_ADDRESS=app.yourdomain.com
