# SITE_ADDRESS is your hostname, e.g. app.yourdomain.com (auto-HTTPS via
# Let's Encrypt when DNS points here and ports 80/443 are open). For a quick
# no-TLS test set SITE_ADDRESS=:80.
{$SITE_ADDRESS} {
	encode zstd gzip

	# Security headers (HSTS assumes HTTPS via the auto cert).
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		-Server
	}

	# API -> FastAPI backend (same origin, so cookies + bearer both work).
	handle /api/* {
		reverse_proxy backend:8000
	}

	# Static SPA. Real files (/, /assets/*) are served directly; unknown paths
	# fall back to index.html so client routes like /admin and /verify work.
	handle {
		root * /srv/dist
		try_files {path} /index.html
		file_server
	}
}
