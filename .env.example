# Trending Table MVP — server-side keys.
# Copy to `.env` (which is gitignored) and fill in real values.

# Google Places API (New) — enable "Places API (New)" in Google Cloud and
# create an API key. Used server-side only for restaurant search/details/photos.
GOOGLE_MAPS_API_KEY=

# Stripe — from https://dashboard.stripe.com/apikeys (use test keys to start).
# The secret key stays on the server; the publishable key is sent to the browser
# via /api/config to initialise Stripe.js.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Menu digitization.
# PDFs are converted to markdown by the MarkItDown Python library (installed in
# ./.venv — see README), then structured into items by an OpenAI-compatible LLM.
# Point these at any provider that serves gpt-oss-120b (Groq, Together, a local
# vLLM/Ollama, …). Without them, items are extracted with a simpler heuristic.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-oss-120b

# Optional: override the Python used to run MarkItDown (defaults to ./.venv/bin/python).
# PYTHON_BIN=

# Optional: production port for `npm start` (defaults to 3000).
# PORT=3000
