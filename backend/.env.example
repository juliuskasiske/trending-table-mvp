# Trending Table backend configuration. Copy to `.env` (gitignored) and fill in.
# ---------------------------------------------------------------------------
# Postgres. Two logical databases on one server:
#   tt_control — platform brain (identities, marketplace, billing)
#   tt_app     — per-restaurant private data (RLS-protected)
# The maintenance URL (postgres db) is used once to CREATE the two databases.
CONTROL_DATABASE_URL=postgresql://juliuskasiske@localhost:5432/tt_control
APP_DATABASE_URL=postgresql://juliuskasiske@localhost:5432/tt_app
# Optional: pin the maintenance DB used for CREATE DATABASE (defaults to the
# control URL with its database swapped to `postgres`).
# MAINTENANCE_DATABASE_URL=postgresql://juliuskasiske@localhost:5432/postgres

# Phase 3: the restricted role the app connects as so RLS is actually enforced
# (a superuser/owner bypasses RLS). Created by the migration runner.
APP_RW_DATABASE_URL=postgresql://tt_app_rw:tt_app_rw@localhost:5432/tt_app

# ---- Secrets (used from Phase 2 on) ---------------------------------------
SESSION_SECRET=            # signs the JWT session cookie
APP_SECRET_KEY=            # Fernet key; encrypts social OAuth tokens at rest

# ---- Integrations (used from Phase 4 on) ----------------------------------
# GOOGLE_MAPS_API_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# Platform-fee prices (€50/mo and annual). Both required to enable subscriptions.
# STRIPE_PRICE_MONTHLY=price_...
# STRIPE_PRICE_ANNUAL=price_...
# Webhook signing secret (Stripe Dashboard → Developers → Webhooks). Optional.
# STRIPE_WEBHOOK_SECRET=whsec_...
# Usage billing: metered €0.01/view price + the meter's event name. Both
# required to bill views; unset means views are only recorded locally.
# STRIPE_PRICE_USAGE=price_...
# STRIPE_METER_EVENT_NAME=trending_table_views
# Optional launch date (YYYY-MM-DD, Europe/Berlin): platform fee trials until
# then, so the first charge lands on this date. Omit to bill immediately.
# STRIPE_SUBSCRIPTION_START=2026-07-13
# LLM_BASE_URL=
# LLM_API_KEY=
# LLM_MODEL=openai/gpt-oss-120b

# ---- Public URL, admin, and email -----------------------------------------
# Base URL of the SPA (verification links + CORS). Dev default: :5174.
# APP_BASE_URL=http://localhost:5174
# Owner control tower (/admin): single access key. Unset = disabled.
# ADMIN_KEY=change-me-owner-key
# SMTP — leave SMTP_HOST blank in dev to just log the verification link.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_STARTTLS=1
# SMTP_SSL=0
# MAIL_FROM=no-reply@example.com
# MAIL_FROM_NAME=Trending Table

# ---- Optional (safe defaults; set only to override) -----------------------
# COOKIE_SECURE=0              # 1 in production (HTTPS) — also flips prod checks on
# SESSION_TTL_HOURS=168
# VERIFY_TOKEN_TTL_HOURS=48
# MAX_FAILED_ATTEMPTS=8
# LOCKOUT_MINUTES=15
# Creator social connect (Instagram/TikTok) — scaffolded, not yet functional:
# META_APP_ID=
# TIKTOK_CLIENT_KEY=
