# Production app config. Copy to backend/.env.prod and fill in. NEVER commit
# the filled file. The DB host is the compose service name `db`; the user and
# password must match POSTGRES_USER / POSTGRES_PASSWORD in infra/.env.

# --- Database (inside the compose network) ---------------------------------
CONTROL_DATABASE_URL=postgresql://tt_owner:change-me-strong-db-password@db:5432/tt_control
APP_DATABASE_URL=postgresql://tt_owner:change-me-strong-db-password@db:5432/tt_app
MAINTENANCE_DATABASE_URL=postgresql://tt_owner:change-me-strong-db-password@db:5432/postgres
# Restricted RLS role. The migration runner creates/syncs this role to whatever
# password you set here — use a strong one (the DB is internal-network only).
APP_RW_DATABASE_URL=postgresql://tt_app_rw:change-me-strong-rw-password@db:5432/tt_app

# --- Security --------------------------------------------------------------
# Generate: openssl rand -hex 32
SESSION_SECRET=change-me-random-hex
# Generate: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
APP_SECRET_KEY=change-me-fernet-key
COOKIE_SECURE=1                       # send the session cookie only over HTTPS

# --- Public URL / CORS -----------------------------------------------------
APP_BASE_URL=https://app.yourdomain.com

# --- Owner control tower ---------------------------------------------------
# Single access key entered on /admin (no account). Use a long random string.
ADMIN_KEY=change-me-to-a-long-random-owner-key

# --- Email (SMTP) — required for verification emails to actually send -------
# Works with Resend, Postmark, Mailgun, SES, Gmail, etc. Leave SMTP_HOST blank
# to fall back to logging the link (no real send).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_STARTTLS=1                       # 1 for port 587; use SMTP_SSL=1 for 465
SMTP_SSL=0
MAIL_FROM=no-reply@yourdomain.com
MAIL_FROM_NAME=Trending Table

# --- Integrations ----------------------------------------------------------
GOOGLE_MAPS_API_KEY=
LLM_BASE_URL=https://api.llmbase.ai/v1
LLM_API_KEY=
LLM_MODEL=openai/gpt-oss-120b
# Stripe — set all four to enable the €50/mo platform-fee subscription.
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_PRICE_MONTHLY=price_...
# STRIPE_PRICE_ANNUAL=price_...
# Webhook signing secret (Developers → Webhooks → your endpoint). Optional.
# STRIPE_WEBHOOK_SECRET=whsec_...
# Usage billing: metered €0.01/view price + the meter's event name.
# STRIPE_PRICE_USAGE=price_...
# STRIPE_METER_EVENT_NAME=trending_table_views
# Launch date (YYYY-MM-DD, Berlin): platform fee trials until then.
# STRIPE_SUBSCRIPTION_START=2026-07-13
# "Welcome" coupon auto-applied to the monthly plan's first month (20% off).
# STRIPE_WELCOME_COUPON=welcome-20-first-month

# --- Optional tuning (safe defaults shown; uncomment only to override) ------
# SESSION_TTL_HOURS=168        # session cookie lifetime (hours) — 7 days
# VERIFY_TOKEN_TTL_HOURS=48    # email-verification link lifetime (hours)
# MAX_FAILED_ATTEMPTS=8        # failed logins before temporary lockout
# LOCKOUT_MINUTES=15           # lockout duration (minutes)

# --- Creator social connect (Instagram/TikTok OAuth) — SCAFFOLDED ----------
# The connect flow is currently dev-mocked and NOT functional. Set these (plus
# the matching app secrets + OAuth redirect base) only once real OAuth is wired.
# META_APP_ID=
# TIKTOK_CLIENT_KEY=
