# Production app config. Copy to backend/.env.prod and fill in. NEVER commit
# the filled file. The DB host is the compose service name `db`; the user and
# password must match POSTGRES_USER / POSTGRES_PASSWORD in infra/.env.

# --- Database (inside the compose network) ---------------------------------
CONTROL_DATABASE_URL=postgresql://tt_owner:change-me-strong-db-password@db:5432/tt_control
APP_DATABASE_URL=postgresql://tt_owner:change-me-strong-db-password@db:5432/tt_app
MAINTENANCE_DATABASE_URL=postgresql://tt_owner:change-me-strong-db-password@db:5432/postgres
# Restricted RLS role. The migration runner creates/syncs this role to whatever
# password you set here — use a strong one (the DB is internal-network only).
APP_RW_DATABASE_URL=postgresql://tt_app_rw:change-me-strong-rw-password@db:5432/tt_app

# --- Security --------------------------------------------------------------
# Generate: openssl rand -hex 32
SESSION_SECRET=change-me-random-hex
# Generate: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
APP_SECRET_KEY=change-me-fernet-key
COOKIE_SECURE=1                       # send the session cookie only over HTTPS

# --- Public URL / CORS -----------------------------------------------------
APP_BASE_URL=https://app.yourdomain.com

# --- Owner control tower ---------------------------------------------------
# Single access key entered on /admin (no account). Use a long random string.
ADMIN_KEY=change-me-to-a-long-random-owner-key

# --- Email (SMTP) — required for verification emails to actually send -------
# Works with Resend, Postmark, Mailgun, SES, Gmail, etc. Leave SMTP_HOST blank
# to fall back to logging the link (no real send).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_STARTTLS=1                       # 1 for port 587; use SMTP_SSL=1 for 465
SMTP_SSL=0
MAIL_FROM=no-reply@yourdomain.com
MAIL_FROM_NAME=Trending Table

# --- Integrations ----------------------------------------------------------
GOOGLE_MAPS_API_KEY=
LLM_BASE_URL=https://api.llmbase.ai/v1
LLM_API_KEY=
LLM_MODEL=openai/gpt-oss-120b
# Stripe (optional; leave blank to keep billing in "coming soon" mode)
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
